#!/usr/bin/env bash
set -euo pipefail

if [[ "${SKIP_GIT_HOOKS:-0}" == "1" ]]; then
  echo "[pre-commit] SKIP_GIT_HOOKS=1, skipping checks."
  exit 0
fi

if ! command -v git >/dev/null 2>&1; then
  echo "[pre-commit] git not found."
  exit 1
fi

staged_files="$(git diff --cached --name-only --diff-filter=ACM)"
if [[ -z "$staged_files" ]]; then
  exit 0
fi

has_kotlin_changes() {
  if command -v rg >/dev/null 2>&1; then
    printf '%s\n' "$staged_files" | rg -q '\.(kt|kts)$'
  else
    printf '%s\n' "$staged_files" | grep -Eq '\.(kt|kts)$'
  fi
}

if ! has_kotlin_changes; then
  echo "[pre-commit] No staged Kotlin/Gradle Kotlin files. Skipping Spotless."
  exit 0
fi

echo "[pre-commit] Running Spotless check..."
./gradlew spotlessCheck
