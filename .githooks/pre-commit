#!/usr/bin/env bash
set -euo pipefail

if [[ "${SKIP_GIT_HOOKS:-0}" == "1" ]]; then
  echo "[pre-commit] SKIP_GIT_HOOKS=1, skipping checks."
  exit 0
fi

if ! command -v git >/dev/null 2>&1; then
  echo "[pre-commit] git not found."
  exit 1
fi

staged_files="$(git diff --cached --name-only --diff-filter=ACM)"
if [[ -z "$staged_files" ]]; then
  exit 0
fi

kotlin_files="$(printf '%s\n' "$staged_files" | grep -E '\.(kt|kts)$' || true)"
if [[ -z "$kotlin_files" ]]; then
  echo "[pre-commit] No staged Kotlin/Gradle Kotlin files. Skipping Spotless."
  exit 0
fi

spotless_targets_csv="$(printf '%s\n' "$kotlin_files" | paste -sd, -)"

echo "[pre-commit] Running Spotless apply for staged Kotlin files..."
./gradlew --quiet --warning-mode=none \
  spotlessKotlinApply spotlessKotlinGradleApply \
  -PspotlessIdeHook="$spotless_targets_csv"

while IFS= read -r file; do
  [[ -n "$file" ]] && git add "$file"
done <<< "$kotlin_files"

echo "[pre-commit] Running Spotless check for staged Kotlin files..."
./gradlew --quiet --warning-mode=none \
  spotlessKotlinCheck spotlessKotlinGradleCheck \
  -PspotlessIdeHook="$spotless_targets_csv"
